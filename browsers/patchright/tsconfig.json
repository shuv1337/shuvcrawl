{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "checkJs": false,
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "patchright_driver_patch.ts",
    "driver_patches/**/*.ts",
    "driver_patches/**/*.js",
    "utils/**/*.ts"
  ]
}