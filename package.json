{
  "name": "shuvcrawl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "scrape": "bun run src/index.ts scrape",
    "map": "bun run src/index.ts map",
    "crawl": "bun run src/index.ts crawl",
    "screenshot": "bun run src/index.ts screenshot",
    "pdf": "bun run src/index.ts pdf",
    "config": "bun run src/index.ts config",
    "version": "bun run src/index.ts version",
    "serve": "bun run src/server.ts",
    "test": "bun test",
    "test:api": "./scripts/test-api-docker.sh",
    "test:integration": "bun test --path-ignore-patterns '' tests/integration/",
    "test:all": "bun test --path-ignore-patterns '' tests/"
  },
  "keywords": ["pi-package"],
  "pi": {
    "skills": ["./skills"]
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "commander": "^14.0.1",
    "hono": "^4.9.8",
    "jsdom": "^27.0.0",
    "patchright": "^1.58.2",
    "turndown": "^7.2.1",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.12.0",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.9.3"
  }
}
